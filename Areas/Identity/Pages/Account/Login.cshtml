@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="col-md-10 col-lg-8">
        <div class="row g-0 shadow rounded-4 overflow-hidden">

            <!-- Left Panel -->
            <div class="col-md-5 d-none d-md-flex flex-column justify-content-center align-items-center p-5 text-white"
                 style="background: linear-gradient(160deg, #1e1b4b 0%, #4c1d95 100%);">
                <i class="bi bi-lightning-charge-fill text-warning mb-3" style="font-size:3rem"></i>
                <h3 class="fw-bold text-center">Welcome Back!</h3>
                <p class="text-center opacity-75 mt-2">Continue your learning journey. Generate AI quizzes, track progress, and climb the leaderboard.</p>
                <div class="mt-4 d-flex flex-column gap-2 w-100">
                    <div class="d-flex align-items-center gap-2 opacity-75">
                        <i class="bi bi-robot text-warning"></i><small>AI-powered quiz generation</small>
                    </div>
                    <div class="d-flex align-items-center gap-2 opacity-75">
                        <i class="bi bi-trophy text-warning"></i><small>Compete on leaderboards</small>
                    </div>
                    <div class="d-flex align-items-center gap-2 opacity-75">
                        <i class="bi bi-graph-up text-warning"></i><small>Track your weak topics</small>
                    </div>
                </div>
            </div>

            <!-- Right Panel -->
            <div class="col-md-7 bg-white p-5">
                <div class="mb-4">
                    <h4 class="fw-bold mb-1">Sign in to QuizAI</h4>
                    <p class="text-muted small">Don't have an account? <a asp-page="./Register" class="text-primary fw-semibold">Register here</a></p>
                </div>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-semibold text-dark">Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-envelope text-muted"></i>
                            </span>
                            <input asp-for="Input.Email" class="form-control border-start-0 ps-0"
                                   autocomplete="username" placeholder="name@example.com" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label asp-for="Input.Password" class="form-label fw-semibold text-dark">Password</label>
                            <a asp-page="./ForgotPassword" class="small text-muted">Forgot password?</a>
                        </div>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock text-muted"></i>
                            </span>
                            <input asp-for="Input.Password" class="form-control border-start-0 ps-0"
                                   autocomplete="current-password" placeholder="Enter your password" id="passwordInput" />
                            <button class="btn btn-light border" type="button" onclick="togglePassword()">
                                <i class="bi bi-eye" id="eyeIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="Input.RememberMe" class="form-check-input" />
                            <label asp-for="Input.RememberMe" class="form-check-label text-muted small">Remember me</label>
                        </div>
                    </div>

                    <button id="login-submit" type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                    </button>

                    <div class="text-center mt-3">
                        <small class="text-muted">
                            <a asp-page="./ResendEmailConfirmation" class="text-muted">Resend email confirmation</a>
                        </small>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
}
