@page
@model LogoutModel
@{
    ViewData["Title"] = "Logged Out";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" style="min-height:60vh;align-items:center">
    <div class="col-md-5 text-center">
        <div class="card shadow">
            <div class="card-body p-5">
                <div style="width:72px;height:72px;background:#eef2ff;border-radius:18px;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem">
                    <i class="bi bi-box-arrow-left" style="font-size:2rem;color:#6366f1"></i>
                </div>
                <h5 style="font-weight:800;margin-bottom:0.5rem">You've been logged out</h5>
                <p style="color:#64748b;margin-bottom:1.5rem">Thanks for using QuizAI. See you next time!</p>
                <div class="d-flex gap-3 justify-content-center">
                    <a asp-page="./Login" class="btn btn-primary px-4">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In Again
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-house me-2"></i>Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
