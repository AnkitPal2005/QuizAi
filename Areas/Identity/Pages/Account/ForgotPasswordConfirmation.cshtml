@page
@{
    ViewData["Title"] = "Check Your Email";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" style="min-height:60vh;align-items:center">
    <div class="col-md-5 text-center">
        <div class="card shadow">
            <div class="card-body p-5">
                <div style="width:72px;height:72px;background:#d1fae5;border-radius:18px;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem">
                    <i class="bi bi-envelope-check-fill text-success fs-2"></i>
                </div>
                <h5 style="font-weight:800;margin-bottom:0.5rem">Check your email!</h5>
                <p style="color:#64748b;margin-bottom:0.5rem">
                    We've sent a password reset link to your email address.
                </p>
                <p style="color:#94a3b8;font-size:0.82rem;margin-bottom:1.5rem">
                    Didn't receive it? Check your spam folder or try again.
                </p>
                <div class="d-flex gap-3 justify-content-center">
                    <a asp-page="./ForgotPassword" class="btn btn-outline-primary px-4">
                        <i class="bi bi-arrow-repeat me-1"></i>Try Again
                    </a>
                    <a asp-page="./Login" class="btn btn-primary px-4">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
