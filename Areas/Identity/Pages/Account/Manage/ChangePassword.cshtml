@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="row g-4">
    <div class="col-md-3">
        <partial name="_ManageNav" />
    </div>
    <div class="col-md-9">
        <div class="card">
            <div class="card-body p-4 p-lg-5">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div style="width:52px;height:52px;background:#ede9fe;border-radius:14px;display:flex;align-items:center;justify-content:center">
                        <i class="bi bi-lock-fill" style="color:#8b5cf6;font-size:1.4rem"></i>
                    </div>
                    <div>
                        <h5 style="font-weight:800;margin:0">Change Password</h5>
                        <p style="color:#64748b;font-size:0.82rem;margin:0">Keep your account secure</p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.StatusMessage))
                {
                    <div class="alert-custom @(Model.StatusMessage.Contains("Error") ? "alert-danger-custom" : "alert-success-custom") mb-4">
                        <i class="bi bi-check-circle-fill"></i>@Model.StatusMessage
                    </div>
                }

                <form id="change-password-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="mb-3">
                        <label asp-for="Input.OldPassword" class="form-label fw-semibold">Current Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock text-muted"></i></span>
                            <input asp-for="Input.OldPassword" type="password" class="form-control border-start-0 ps-0"
                                   placeholder="Your current password" autocomplete="current-password" />
                        </div>
                        <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.NewPassword" class="form-label fw-semibold">New Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill text-muted"></i></span>
                            <input asp-for="Input.NewPassword" type="password" class="form-control border-start-0 ps-0"
                                   placeholder="Min 6 characters" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">Confirm New Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-shield-lock text-muted"></i></span>
                            <input asp-for="Input.ConfirmPassword" type="password" class="form-control border-start-0 ps-0"
                                   placeholder="Repeat new password" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary px-5 py-2">
                        <i class="bi bi-check-lg me-2"></i>Update Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
