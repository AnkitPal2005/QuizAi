@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center align-items-center" style="min-height:70vh">
    <div class="col-md-10 col-lg-7">
        <div class="row g-0 shadow rounded-4 overflow-hidden">
            <div class="col-md-5 d-none d-md-flex flex-column justify-content-center align-items-center p-5 text-white"
                 style="background:linear-gradient(160deg,#0f172a,#1e1b4b,#4c1d95)">
                <div style="width:64px;height:64px;background:rgba(245,158,11,0.2);border-radius:18px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem">
                    <i class="bi bi-key-fill text-warning fs-2"></i>
                </div>
                <h4 style="font-weight:800;text-align:center">Forgot Password?</h4>
                <p style="color:rgba(255,255,255,0.6);font-size:0.875rem;text-align:center;margin-top:0.5rem">
                    No worries! Enter your email and we'll send you a reset link.
                </p>
            </div>
            <div class="col-md-7 bg-white p-5">
                <h5 style="font-weight:800;margin-bottom:0.25rem">Reset your password</h5>
                <p style="color:#64748b;font-size:0.875rem;margin-bottom:1.5rem">
                    Remember it? <a asp-page="./Login" style="color:#6366f1;font-weight:600">Sign in</a>
                </p>
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label fw-semibold">Email address</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope text-muted"></i></span>
                            <input asp-for="Input.Email" class="form-control border-start-0 ps-0"
                                   placeholder="name@example.com" autocomplete="username" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                        <i class="bi bi-send me-2"></i>Send Reset Link
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
