@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Confirm Email";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" style="min-height:60vh;align-items:center">
    <div class="col-md-6 col-lg-5 text-center">
        <div class="card shadow">
            <div class="card-body p-5">
                @if (Model.StatusMessage?.Contains("Error") == true)
                {
                    <div style="width:72px;height:72px;background:#fee2e2;border-radius:18px;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem">
                        <i class="bi bi-x-circle-fill text-danger fs-2"></i>
                    </div>
                    <h5 style="font-weight:800;color:#ef4444">Confirmation Failed</h5>
                    <p style="color:#64748b">@Model.StatusMessage</p>
                }
                else
                {
                    <div style="width:72px;height:72px;background:#d1fae5;border-radius:18px;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem">
                        <i class="bi bi-check-circle-fill text-success fs-2"></i>
                    </div>
                    <h5 style="font-weight:800">Email Confirmed!</h5>
                    <p style="color:#64748b;margin-bottom:1.5rem">Your email has been confirmed. You can now sign in.</p>
                    <a asp-page="./Login" class="btn btn-primary px-5 py-2">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                    </a>
                }
            </div>
        </div>
    </div>
</div>
