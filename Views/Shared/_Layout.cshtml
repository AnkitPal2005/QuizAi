<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — QuizAI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<nav class="site-navbar">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-4">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-lightning-charge-fill text-warning me-1"></i>QuizAI
                </a>
                <div class="nav-links d-none d-lg-flex align-items-center gap-1">
                    <a class="nav-link" asp-controller="Quiz" asp-action="Index">
                        <i class="bi bi-collection me-1"></i>Browse
                    </a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Admin") || User.IsInRole("Mentor"))
                        {
                            <a class="nav-link" asp-controller="Quiz" asp-action="Generate">
                                <i class="bi bi-robot me-1"></i>AI Generate
                            </a>
                        }
                        <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-speedometer2 me-1"></i>Dashboard
                        </a>
                    }
                    <a class="nav-link" asp-controller="Quiz" asp-action="Leaderboard">
                        <i class="bi bi-trophy me-1"></i>Leaderboard
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="nav-link nav-admin" asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-shield-check me-1"></i>Admin
                        </a>
                    }
                </div>
            </div>
            <partial name="_LoginPartial" />
        </div>
    </div>
</nav>

<main class="site-main">
    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert-custom alert-success-custom mb-4" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span>@TempData["Success"]</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-custom alert-danger-custom mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@TempData["Error"]</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
</main>

<footer class="site-footer">
    <div class="container text-center">
        &copy; @DateTime.Now.Year QuizAI &mdash; Powered by Groq AI
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
