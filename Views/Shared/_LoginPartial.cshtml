@using Microsoft.AspNetCore.Identity
@using AIQuizPlatform.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<div class="d-flex align-items-center gap-2">
@if (SignInManager.IsSignedIn(User))
{
    var currentUser = await UserManager.GetUserAsync(User);
    <div class="dropdown">
        <button class="btn d-flex align-items-center gap-2 px-2 px-md-3 py-2"
                style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.12);color:#fff;border-radius:9px"
                data-bs-toggle="dropdown">
            <div style="width:28px;height:28px;background:var(--primary);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:0.78rem;font-weight:700;color:#fff;flex-shrink:0">
                @(string.IsNullOrEmpty(currentUser?.FullName) ? "U" : currentUser.FullName[0].ToString().ToUpper())
            </div>
            <span style="font-size:0.85rem;font-weight:500" class="d-none d-md-inline">
                @(currentUser?.FullName?.Split(' ')[0] ?? "User")
            </span>
            <i class="bi bi-chevron-down d-none d-md-inline" style="font-size:0.7rem;opacity:0.6"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow" style="border-radius:12px;border:1px solid #e2e8f0;min-width:180px;padding:0.4rem">
            <li>
                <a class="dropdown-item rounded-2" asp-controller="Dashboard" asp-action="Index"
                   style="font-size:0.875rem;padding:0.5rem 0.75rem">
                    <i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard
                </a>
            </li>
            <li>
                <a class="dropdown-item rounded-2" asp-area="Identity" asp-page="/Account/Manage/Index"
                   style="font-size:0.875rem;padding:0.5rem 0.75rem">
                    <i class="bi bi-person me-2 text-muted"></i>Profile
                </a>
            </li>
            <li><hr class="dropdown-divider my-1"></li>
            <li>
                <form asp-area="Identity" asp-page="/Account/Logout"
                      asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button type="submit" class="dropdown-item rounded-2"
                            style="font-size:0.875rem;padding:0.5rem 0.75rem;color:#ef4444">
                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                    </button>
                </form>
            </li>
        </ul>
    </div>
}
else
{
    <a asp-area="Identity" asp-page="/Account/Register"
       class="d-none d-md-inline"
       style="color:rgba(255,255,255,0.7);font-size:0.875rem;font-weight:500;text-decoration:none;padding:0.4rem 0.75rem">
        Register
    </a>
    <a asp-area="Identity" asp-page="/Account/Login"
       class="btn btn-primary btn-sm px-3"
       style="border-radius:8px;font-size:0.875rem">
        Login
    </a>
}
</div>
