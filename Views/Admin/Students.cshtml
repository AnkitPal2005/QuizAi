@model List<AIQuizPlatform.Models.ApplicationUser>
@{
    ViewData["Title"] = "Manage Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 style="font-weight:800;margin-bottom:0.2rem">Manage Students</h4>
        <p style="color:#64748b;font-size:0.875rem;margin:0">@Model.Count student(s) registered</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm px-3">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
        <a asp-action="AddStudent" class="btn btn-primary btn-sm px-3">
            <i class="bi bi-plus-lg me-1"></i>Add Student
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <div style="width:64px;height:64px;background:#e0f2fe;border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
                <i class="bi bi-mortarboard" style="font-size:1.8rem;color:#0ea5e9"></i>
            </div>
            <h6 style="font-weight:700">No students yet</h6>
            <p style="color:#64748b;font-size:0.875rem">Students will appear here after they register</p>
            <a asp-action="AddStudent" class="btn btn-primary px-4">
                <i class="bi bi-plus-lg me-1"></i>Add Student
            </a>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead style="background:#f8fafc">
                        <tr style="font-size:0.78rem;color:#64748b;text-transform:uppercase;letter-spacing:0.5px">
                            <th class="ps-4">Student</th>
                            <th>Email</th>
                            <th>XP / Level</th>
                            <th>Joined</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:36px;height:36px;background:#e0f2fe;border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem;color:#0ea5e9">
                                            @(string.IsNullOrEmpty(user.FullName) ? "?" : user.FullName[0].ToString().ToUpper())
                                        </div>
                                        <span style="font-weight:600;font-size:0.875rem">@(user.FullName ?? "—")</span>
                                    </div>
                                </td>
                                <td style="color:#64748b;font-size:0.875rem">@user.Email</td>
                                <td>
                                    <span style="background:#eef2ff;color:#6366f1;font-size:0.75rem;padding:3px 8px;border-radius:5px;font-weight:600">
                                        @user.XP XP · Lv.@user.Level
                                    </span>
                                </td>
                                <td style="color:#94a3b8;font-size:0.8rem">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="EditStudent" asp-route-id="@user.Id"
                                           class="btn btn-sm btn-outline-primary px-3">
                                            <i class="bi bi-pencil me-1"></i>Edit
                                        </a>
                                        <form method="post" asp-action="DeleteStudent" asp-route-id="@user.Id"
                                              onsubmit="return confirm('Delete student @user.FullName?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger px-3">
                                                <i class="bi bi-trash me-1"></i>Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
