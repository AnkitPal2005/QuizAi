@model List<AIQuizPlatform.Models.Quiz>
@{
    ViewData["Title"] = "Manage Quizzes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-collection me-2 text-success"></i>Quizzes (@Model.Count)</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Title</th>
                        <th>Category</th>
                        <th>Difficulty</th>
                        <th>Questions</th>
                        <th>Source</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var quiz in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@quiz.Title</td>
                            <td><span class="badge bg-light text-dark">@quiz.Category.Name</span></td>
                            <td>
                                <span class="badge @(quiz.Difficulty == AIQuizPlatform.Models.Difficulty.Easy ? "bg-success" : quiz.Difficulty == AIQuizPlatform.Models.Difficulty.Medium ? "bg-warning text-dark" : "bg-danger")">
                                    @quiz.Difficulty
                                </span>
                            </td>
                            <td>@quiz.Questions.Count</td>
                            <td>
                                @if (quiz.IsAIGenerated)
                                {
                                    <span class="badge bg-primary"><i class="bi bi-robot me-1"></i>AI</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Manual</span>
                                }
                            </td>
                            <td>
                                @if (quiz.IsPublished)
                                {
                                    <span class="badge bg-success">Published</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Hidden</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <form method="post" asp-action="ToggleQuiz" asp-route-id="@quiz.Id">
                                        <button type="submit" class="btn btn-sm @(quiz.IsPublished ? "btn-outline-warning" : "btn-outline-success")">
                                            @(quiz.IsPublished ? "Hide" : "Publish")
                                        </button>
                                    </form>
                                    <form method="post" asp-action="DeleteQuiz" asp-route-id="@quiz.Id"
                                          onsubmit="return confirm('Delete this quiz?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
