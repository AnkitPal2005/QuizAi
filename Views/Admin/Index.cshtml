@{
    ViewData["Title"] = "Admin Panel";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 style="font-weight:800;margin-bottom:0.2rem">Admin Panel</h4>
        <p style="color:#64748b;font-size:0.875rem;margin:0">Manage your platform</p>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    @{
        var stats = new (string Icon, string Color, string Bg, string Label, object Value)[] {
            ("bi-people-fill",     "#6366f1", "#eef2ff", "Total Users",   ViewBag.TotalUsers),
            ("bi-person-badge",    "#8b5cf6", "#ede9fe", "Mentors",       ViewBag.TotalMentors),
            ("bi-mortarboard",     "#0ea5e9", "#e0f2fe", "Students",      ViewBag.TotalStudents),
            ("bi-collection-fill", "#10b981", "#d1fae5", "Total Quizzes", ViewBag.TotalQuizzes),
            ("bi-check2-all",      "#f59e0b", "#fef3c7", "Attempts",      ViewBag.TotalAttempts),
            ("bi-robot",           "#ef4444", "#fee2e2", "AI Generated",  ViewBag.AIGenerated),
        };
    }
    @foreach (var (Icon, Color, Bg, Label, Value) in stats)
    {
        <div class="col-6 col-md-4 col-lg-2">
            <div class="card stat-card text-center">
                <div class="card-body p-3">
                    <div class="stat-icon mx-auto" style="background:@Bg;width:44px;height:44px;font-size:1.2rem">
                        <i class="bi @Icon" style="color:@Color"></i>
                    </div>
                    <div style="font-size:1.4rem;font-weight:800;line-height:1.2">@Value</div>
                    <div style="font-size:0.75rem;color:#64748b">@Label</div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Manage Cards -->
<div class="section-title">
    <div style="width:4px;height:20px;background:var(--primary);border-radius:2px"></div>
    Manage
</div>
<div class="row g-3">

    <div class="col-md-6 col-lg-3">
        <a asp-controller="Admin" asp-action="Mentors" class="card quiz-card text-decoration-none h-100">
            <div class="card-body p-4">
                <div style="width:52px;height:52px;border-radius:14px;background:#ede9fe;display:flex;align-items:center;justify-content:center;margin-bottom:1rem">
                    <i class="bi bi-person-badge-fill" style="color:#8b5cf6;font-size:1.4rem"></i>
                </div>
                <h6 style="font-weight:700;margin-bottom:0.3rem;color:#1e293b">Manage Mentors</h6>
                <p style="color:#64748b;font-size:0.82rem;margin:0">Add, edit or remove mentors</p>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a asp-controller="Admin" asp-action="Students" class="card quiz-card text-decoration-none h-100">
            <div class="card-body p-4">
                <div style="width:52px;height:52px;border-radius:14px;background:#e0f2fe;display:flex;align-items:center;justify-content:center;margin-bottom:1rem">
                    <i class="bi bi-mortarboard-fill" style="color:#0ea5e9;font-size:1.4rem"></i>
                </div>
                <h6 style="font-weight:700;margin-bottom:0.3rem;color:#1e293b">Manage Students</h6>
                <p style="color:#64748b;font-size:0.82rem;margin:0">Add, edit or remove students</p>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a asp-controller="Admin" asp-action="Quizzes" class="card quiz-card text-decoration-none h-100">
            <div class="card-body p-4">
                <div style="width:52px;height:52px;border-radius:14px;background:#d1fae5;display:flex;align-items:center;justify-content:center;margin-bottom:1rem">
                    <i class="bi bi-collection-fill" style="color:#10b981;font-size:1.4rem"></i>
                </div>
                <h6 style="font-weight:700;margin-bottom:0.3rem;color:#1e293b">Manage Quizzes</h6>
                <p style="color:#64748b;font-size:0.82rem;margin:0">Publish, hide or delete quizzes</p>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a asp-controller="Quiz" asp-action="Leaderboard" class="card quiz-card text-decoration-none h-100">
            <div class="card-body p-4">
                <div style="width:52px;height:52px;border-radius:14px;background:#fef3c7;display:flex;align-items:center;justify-content:center;margin-bottom:1rem">
                    <i class="bi bi-trophy-fill" style="color:#f59e0b;font-size:1.4rem"></i>
                </div>
                <h6 style="font-weight:700;margin-bottom:0.3rem;color:#1e293b">Leaderboard</h6>
                <p style="color:#64748b;font-size:0.82rem;margin:0">View top performers</p>
            </div>
        </a>
    </div>

</div>
